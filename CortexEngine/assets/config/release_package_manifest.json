{
  "schema": 1,
  "package_id": "cortex-public-review",
  "description": "Public-review package contract for the validated Cortex renderer build.",
  "max_package_bytes": 536870912,
  "required_docs": [
    "README.md",
    "BUILD.md",
    "SCRIPTS.md",
    "RELEASE_READINESS.md",
    "tools/README.md",
    "docs/media/gallery_manifest.json",
    "docs/media/video_manifest.json",
    "docs/media/rt_showcase_hero.png",
    "docs/media/rt_showcase_reflection_closeup.png",
    "docs/media/rt_showcase_material_overview.png",
    "docs/media/material_lab_hero.png",
    "docs/media/material_lab_metal_closeup.png",
    "docs/media/material_lab_glass_emissive.png",
    "docs/media/glass_water_courtyard_hero.png",
    "docs/media/glass_water_courtyard_water_closeup.png",
    "docs/media/glass_water_courtyard_glass_canopy.png",
    "docs/media/effects_showcase_hero.png",
    "docs/media/effects_showcase_particles_closeup.png",
    "docs/media/effects_showcase_neon_materials.png",
    "docs/media/outdoor_sunset_beach_hero.png",
    "docs/media/outdoor_sunset_beach_waterline.png",
    "docs/media/liquid_gallery_hero.png",
    "docs/media/liquid_gallery_water_lava.png",
    "docs/media/liquid_gallery_viscous_pair.png",
    "docs/media/ibl_gallery_hero.png",
    "docs/media/ibl_gallery_sweep.png",
    "docs/media/cortex_gallery_reel.mp4"
  ],
  "required_source_files": [
    "assets/config/release_package_manifest.json"
  ],
  "required_runtime_files": [
    "CortexEngine.exe",
    "SDL3.dll",
    "dxcompiler.dll",
    "fmt.dll",
    "spdlog.dll",
    "assets/config/advanced_graphics_catalog.json",
    "assets/config/graphics_presets.json",
    "assets/config/renderer_ownership_targets.json",
    "assets/config/render_quality.json",
    "assets/config/showcase_scenes.json",
    "assets/config/visual_baselines.json",
    "assets/environments/environments.json",
    "assets/shaders/RaytracedReflections.dxil",
    "assets/shaders/RaytracedShadows.dxil",
    "assets/shaders/RaytracedGI.dxil"
  ],
  "runtime_include_globs": [
    "CortexEngine.exe",
    "SDL3.dll",
    "dxcompiler.dll",
    "fmt.dll",
    "spdlog.dll",
    "ggml*.dll",
    "llama.dll",
    "assets/config/*.json",
    "assets/*.dds",
    "assets/environments/*.json",
    "assets/shaders/*.hlsl",
    "assets/shaders/*.hlsli",
    "assets/shaders/*.dxil",
    "assets/textures/rtshowcase/*.dds"
  ],
  "package_forbidden_globs": [
    "models/*",
    "logs/*",
    "build/*",
    "vcpkg_installed/*",
    "*.pdb",
    "*.ilk",
    "*.obj",
    "*.lib",
    "*.exp",
    "*.log",
    "run*.txt",
    "assets/*.hdr",
    "assets/*.exr",
    "assets/**/*.hdr",
    "assets/**/*.exr",
    "assets/**/*.blend"
  ],
  "required_release_validation_steps": [
    "build_release",
    "repo_hygiene",
    "launcher_native_widget",
    "graphics_native_widget",
    "graphics_material_controls",
    "material_editor_native_widget",
    "liquid_graphics_contract",
    "rt_showcase",
    "liquid_gallery",
    "phase3_visual_matrix",
    "renderer_full_ownership_audit",
    "rt_firefly_outlier",
    "rt_overbright_clamp",
    "release_package_launch_smoke",
    "budget_profile_matrix"
  ]
}
