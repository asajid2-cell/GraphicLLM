{
  "recording": {
    "duration": 60,
    "framerate": 30,
    "quality": "ultrafast",
    "output_directory": "test_recordings"
  },
  "build": {
    "skip_build": false,
    "build_config": "Release"
  },
  "commands": {
    "wait_before_commands": 5,
    "key_sequences": [
      {
        "description": "Test WASD movement",
        "keys": ["w", "a", "s", "d"],
        "delay_between_keys": 500,
        "delay_after_sequence": 1000
      },
      {
        "description": "Test jump/interact",
        "keys": [" "],
        "delay_after_sequence": 1000
      },
      {
        "description": "Open menu",
        "keys": ["{ESC}"],
        "delay_after_sequence": 1000
      }
    ],
    "custom_notes": "Edit this file to customize your test automation. Keys use SendKeys format: letters, {ESC}, {ENTER}, {F1}, etc."
  }
}
